# === Discord Bot 設定 ===

# 機器人的 Discord Token（從 Discord Developer Portal 取得）
DISCORD_TOKEN=你的 Discord Bot Token

# 機器人的應用程式 ID（用於 Slash 指令註冊）
CLIENT_ID=你的 Discord App Client ID

# 機器人擁有者的 Discord 使用者 ID（限制某些管理指令）
BOT_OWNER_ID=你的 Discord 使用者 ID

# 機器人的狀態（可選：online、idle、dnd）
BOT_STATUS=online

# 機器人顯示的活動類型（可選：Playing、Watching、Listening、Competing）
BOT_ACTIVITY_TYPE=Playing

# 機器人顯示的活動名稱（例：GPTjsbot | /help）
BOT_ACTIVITY_NAME=GPTjsbot | /help

# === Groq 設定 ===

# 用於 AI 對話功能的 API Key（從 Groq 取得）
GROQ_API_KEY=你的 Groq API Key

# 預設使用的 AI 模型（可選，預設為 llama-3.3-70b-versatile）
# 常用模型：llama-3.3-70b-versatile, llama-3.1-8b-instant, openai/gpt-oss-120b, openai/gpt-oss-20b, qwen/qwen3.6-27b, qwen/qwen3-32b, meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL=llama-3.3-70b-versatile

# 自訂 AI 的 System Prompt（角色設定，可選）
GROQ_SYSTEM_PROMPT=你是一位專業且親切的 Discord 智慧助手。請用繁體中文回覆，語氣友善且適度使用 Markdown 與表情符號。
